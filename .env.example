# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-a-long-random-secret
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Database (Supabase / PostgreSQL 16) ──────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/stylemirror

# ─── Supabase Auth ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ─── Cloudflare R2 (file storage) ─────────────────────────────────────────────
R2_ACCOUNT_ID=your-cloudflare-account-id
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_BUCKET_NAME=stylemirror-media
R2_PUBLIC_URL=https://media.stylemirror.ai

# ─── Upstash Redis (cache / queues) ───────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# ─── AI — Anthropic Claude ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# ─── AI — Replicate (IDM-VTON try-on, FLUX image gen) ────────────────────────
REPLICATE_API_TOKEN=r8_your-replicate-api-token

# ─── Vector DB — Qdrant Cloud ─────────────────────────────────────────────────
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# ─── Search — Typesense ───────────────────────────────────────────────────────
TYPESENSE_HOST=your-typesense-host.railway.app
TYPESENSE_PORT=443
TYPESENSE_PROTOCOL=https
TYPESENSE_API_KEY=your-typesense-api-key

# ─── Email — Resend ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@stylemirror.ai

# ─── Push — Firebase Cloud Messaging ─────────────────────────────────────────
FCM_PROJECT_ID=your-firebase-project-id
FCM_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FCM_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ─── Monitoring — Sentry ──────────────────────────────────────────────────────
SENTRY_DSN=https://your-key@sentry.io/your-project
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/your-project

# ─── Logging — Axiom ─────────────────────────────────────────────────────────
AXIOM_DATASET=stylemirror-logs
AXIOM_TOKEN=your-axiom-token

# ─── Background Jobs — Trigger.dev ───────────────────────────────────────────
TRIGGER_API_KEY=your-trigger-api-key
TRIGGER_API_URL=https://api.trigger.dev
