generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  emailVerified DateTime?
  password      String?
  role          String    @default("user")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  familyProfiles  FamilyProfile[]
  uploadedMedia   UploadedMedia[]
  recommendations Recommendation[]
  savedItems      SavedItem[]
  tryonImages     TryonImage[]
  tryonVideos     TryonVideo[]
  arSessions      ArSession[]
  conversations   StylistConversation[]
  auditLogs       AuditLog[]
  fitFeedback     FitFeedback[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model FamilyProfile {
  id              String   @id @default(cuid())
  userId          String
  name            String
  relationship    String
  ageGroup        String
  gender          String
  height          Float?
  weight          Float?
  bodyShape       String?
  clothingSize    String?
  shoeSize        String?
  fitPreference   String?
  stylePreference String[]
  favoriteBrands  String[]
  favoriteColors  String[]
  dislikedColors  String[]
  avatarUrl       String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user             User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  measurements     BodyMeasurement[]
  modelVersions    BodyModelVersion[]
  uploadedMedia    UploadedMedia[]
  stylePreferences StylePreference[]
  skinToneProfile  SkinToneProfile?
  recommendations  Recommendation[]
  savedItems       SavedItem[]
  tryonImages      TryonImage[]
  arSessions       ArSession[]
  conversations    StylistConversation[]
  colorAnalyses    ColorAnalysisResult[]
  fitFeedback      FitFeedback[]
}

model BodyMeasurement {
  id                 String    @id @default(cuid())
  profileId          String
  chest              Float?
  waist              Float?
  hip                Float?
  shoulder           Float?
  inseam             Float?
  armLength          Float?
  neckCircumference  Float?
  bustSize           String?
  thighCircumference Float?
  calfCircumference  Float?
  unit               String    @default("cm")
  confidence         Float?
  isConfirmed        Boolean   @default(false)
  confirmedAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  profile FamilyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model BodyModelVersion {
  id               String   @id @default(cuid())
  profileId        String
  modelData        Json
  estimationMethod String
  generationParams Json?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  profile FamilyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model UploadedMedia {
  id        String   @id @default(cuid())
  userId    String
  profileId String?
  type      String
  url       String
  publicId  String?
  width     Int?
  height    Int?
  purpose   String?
  createdAt DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile FamilyProfile? @relation(fields: [profileId], references: [id])
}

model StylePreference {
  id             String   @id @default(cuid())
  profileId      String
  occasions      String[]
  aesthetics     String[]
  colorPalette   String[]
  avoidColors    String[]
  budgetMin      Float?
  budgetMax      Float?
  favoriteBrands String[]
  currency       String   @default("USD")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  profile FamilyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model SkinToneProfile {
  id               String   @id @default(cuid())
  profileId        String   @unique
  undertone        String?
  season           String?
  fitzpatrickScale Int?
  dominantColors   String[]
  bestColors       String[]
  avoidColors      String[]
  analysisSource   String?
  analysisData     Json?
  createdAt        DateTime @default(now())

  profile FamilyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?  @db.Text
  brand       String?
  category    String
  subcategory String?
  gender      String?
  ageGroup    String?
  images      String[]
  tags        String[]
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  variants        ProductVariant[]
  recommendations Recommendation[]
  savedItems      SavedItem[]
  tryonImages     TryonImage[]
  prices          StorePrice[]
  fitFeedback     FitFeedback[]
}

model ProductVariant {
  id          String   @id @default(cuid())
  productId   String
  color       String?
  colorHex    String?
  size        String?
  price       Float
  currency    String   @default("USD")
  sku         String?
  stockStatus String   @default("in_stock")
  images      String[]

  product     Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  prices      StorePrice[]
  savedItems  SavedItem[]
  tryonImages TryonImage[]
}

model Store {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logoUrl   String?
  website   String?
  country   String?
  rating    Float?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  prices StorePrice[]
}

model StorePrice {
  id               String   @id @default(cuid())
  productVariantId String
  storeId          String
  price            Float
  currency         String   @default("USD")
  originalPrice    Float?
  discount         Float?
  url              String?
  inStock          Boolean  @default(true)
  shippingInfo     String?
  lastChecked      DateTime @default(now())

  variant   ProductVariant @relation(fields: [productVariantId], references: [id], onDelete: Cascade)
  store     Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  Product   Product?       @relation(fields: [productId], references: [id])
  productId String?
}

model Recommendation {
  id         String   @id @default(cuid())
  userId     String
  profileId  String
  productId  String
  score      Float
  reasons    String[]
  occasion   String?
  colorScore Float?
  fitScore   Float?
  styleScore Float?
  createdAt  DateTime @default(now())

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile FamilyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model SavedItem {
  id        String   @id @default(cuid())
  userId    String
  profileId String?
  productId String
  variantId String?
  notes     String?
  createdAt DateTime @default(now())

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile FamilyProfile?  @relation(fields: [profileId], references: [id])
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])
}

model TryonImage {
  id               String   @id @default(cuid())
  userId           String
  profileId        String
  productId        String
  variantId        String?
  imageUrl         String
  modelImageUrl    String?
  generationParams Json?
  isAiGenerated    Boolean  @default(true)
  rating           Int?
  createdAt        DateTime @default(now())

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile FamilyProfile   @relation(fields: [profileId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id])
  videos  TryonVideo[]
}

model TryonVideo {
  id           String   @id @default(cuid())
  userId       String
  tryonImageId String
  videoUrl     String
  style        String?
  duration     Int?
  withMusic    Boolean  @default(false)
  orientation  String   @default("portrait")
  status       String   @default("pending")
  createdAt    DateTime @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  tryonImage TryonImage @relation(fields: [tryonImageId], references: [id], onDelete: Cascade)
}

model ArSession {
  id            String   @id @default(cuid())
  userId        String
  profileId     String
  productIds    String[]
  mode          String?
  screenshotUrl String?
  recordingUrl  String?
  deviceInfo    Json?
  createdAt     DateTime @default(now())

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile FamilyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model StylistConversation {
  id        String   @id @default(cuid())
  userId    String
  profileId String
  messages  Json
  context   Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  profile FamilyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model ColorAnalysisResult {
  id                  String   @id @default(cuid())
  profileId           String
  inputImageUrl       String?
  undertone           String?
  complementaryColors String[]
  warningColors       String[]
  seasonalPalette     String?
  recommendations     Json?
  createdAt           DateTime @default(now())

  profile FamilyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model FitFeedback {
  id           String   @id @default(cuid())
  userId       String
  productId    String
  profileId    String
  rating       Int
  fitAccuracy  Int?
  sizeAccuracy Int?
  notes        String?
  createdAt    DateTime @default(now())

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  profile FamilyProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  resource   String
  resourceId String?
  metadata   Json?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}
